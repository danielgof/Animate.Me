<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="AnimateMe.HomePage"
             Title="Animate.Me"
             BackgroundColor="#F5F7FB">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="24"
                             HorizontalOptions="Center"
                             MaximumWidthRequest="720">

            <!-- HEADER -->
            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                <Label Text="Motion Capture Studio"
                       FontSize="30"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="#111827"/>

                <Label Text="Upload a video and generate 3D motion data instantly"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="#6B7280"/>
            </VerticalStackLayout>

            <!-- MAIN CARD -->
            <Border StrokeShape="RoundRectangle 24"
                    BackgroundColor="White"
                    Padding="0">

                <Border.Shadow>
                    <Shadow Brush="Black"
                            Opacity="0.06"
                            Radius="25"
                            Offset="0,12"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="0">

                    <!-- VIDEO PREVIEW AREA -->
                    <Grid HeightRequest="320"
                          BackgroundColor="#F3F4F6">

                        <toolkit:MediaElement
                            x:Name="videoPlayer"
                            Aspect="AspectFill"
                            HeightRequest="320"/>

                        <!-- Empty state overlay -->
                        <VerticalStackLayout HorizontalOptions="Center"
                                             VerticalOptions="Center"
                                             Spacing="10">

                            <Label Text="Drop or upload a video"
                                   FontSize="16"
                                   TextColor="#9CA3AF"
                                   HorizontalTextAlignment="Center"/>

                            <Label Text="MP4, MOV supported"
                                   FontSize="12"
                                   TextColor="#C4C7CE"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>

                        <ActivityIndicator x:Name="loadingSpinner"
                                           IsRunning="False"
                                           Color="#6366F1"
                                           WidthRequest="40"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                    </Grid>

                    <!-- ACTION AREA -->
                    <VerticalStackLayout Padding="20"
                                         Spacing="12">

                        <ProgressBar x:Name="progressBar"
                                     Progress="0"
                                     IsVisible="False"/>

                        <!-- PRIMARY CTA -->
                        <Button Text="Upload Video"
                                BackgroundColor="#4F46E5"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                HeightRequest="52"
                                Clicked="OnUploadFile">
                            <Button.Shadow>
                                <Shadow Brush="#4F46E5"
                                        Opacity="0.25"
                                        Offset="0,6"
                                        Radius="12"/>
                            </Button.Shadow>
                        </Button>

                        <!-- SECONDARY CTA -->
                        <Button x:Name="downloadButton"
                                Text="Download BVH"
                                BackgroundColor="#10B981"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="46"
                                IsVisible="False"
                                Clicked="OnDownloadClicked"/>

                        <Label Text="Processing happens locally. No video is stored."
                               FontSize="11"
                               HorizontalTextAlignment="Center"
                               TextColor="#9CA3AF"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>