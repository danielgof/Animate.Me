<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="AnimateMe.HomePage"
             Title="Animate.Me"
             BackgroundColor="#0F172A">

    <Grid RowDefinitions="*,Auto"
          Padding="12"
          BackgroundColor="#0F172A">

        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 28"
                BackgroundColor="#111827"
                Padding="0"
                Margin="0,0,0,12">
            <Grid>
                <toolkit:MediaElement x:Name="videoPlayer"
                                      Aspect="AspectFill"
                                      HorizontalOptions="Fill"
                                      VerticalOptions="Fill"/>

                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="10"
                                     Padding="24">
                    <Label Text="Drop or upload a video"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#E5E7EB"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="MP4, MOV supported"
                           FontSize="13"
                           TextColor="#9CA3AF"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <ActivityIndicator x:Name="loadingSpinner"
                                   IsRunning="False"
                                   Color="#6366F1"
                                   WidthRequest="44"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                StrokeShape="RoundRectangle 24"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="18">
            <VerticalStackLayout Spacing="12">
                <ProgressBar x:Name="progressBar"
                             Progress="0"
                             IsVisible="False"/>

                <HorizontalStackLayout Spacing="12"
                                       HorizontalOptions="Center">
                    <Button Text="Upload Video"
                            BackgroundColor="#4F46E5"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            HeightRequest="50"
                            Clicked="OnUploadFile"/>

                    <Button x:Name="downloadButton"
                            Text="Download BVH"
                            BackgroundColor="#10B981"
                            TextColor="White"
                            CornerRadius="14"
                            HeightRequest="50"
                            IsVisible="False"
                            Clicked="OnDownloadClicked"/>
                </HorizontalStackLayout>

                <Label Text="Processing happens locally. No video is stored."
                       FontSize="11"
                       HorizontalTextAlignment="Center"
                       TextColor="#9CA3AF"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>